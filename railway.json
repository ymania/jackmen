{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "root": "backend",
    "builder": "NIXPACKS",
    "providers": ["python"]
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
